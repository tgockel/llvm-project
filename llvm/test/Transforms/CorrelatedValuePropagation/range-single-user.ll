; %n is known to be non-negative, so umax(%n, 1) == %n and the exit condition
; icmp eq 0, %umax is known false. The only user of %umax is the the compare in
; the loop.
define i64 @test_umax_single_user_across_loop(i64 %n) {
; CHECK-LABEL: define i64 @test_umax_single_user_across_loop(
; CHECK-SAME: i64 [[N:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[Z:%.*]] = icmp eq i64 [[N]], 0
; CHECK-NEXT:    br i1 [[Z]], label %[[EXIT:.*]], label %[[PH:.*]]
; CHECK:       [[PH]]:
; CHECK-NEXT:    br label %[[LOOP_HEADER:.*]]
; CHECK:       [[LOOP_HEADER]]:
; CHECK-NEXT:    call void @foo()
; CHECK-NEXT:    br label %[[LOOP_LATCH:.*]]
; CHECK:       [[LOOP_LATCH]]:
; CHECK-NEXT:    [[EC:%.*]] = icmp eq i64 0, [[N]]
; CHECK-NEXT:    br i1 [[EC]], label %[[EXIT]], label %[[LOOP_HEADER]]
; CHECK:       [[EXIT]]:
; CHECK-NEXT:    ret i64 [[N]]
;
entry:
  %z = icmp eq i64 %n, 0
  br i1 %z, label %exit, label %ph

ph:
  %umax = call i64 @llvm.umax.i64(i64 %n, i64 1)
  br label %loop.header

loop.header:
  call void @foo()
  br label %loop.latch

loop.latch:
