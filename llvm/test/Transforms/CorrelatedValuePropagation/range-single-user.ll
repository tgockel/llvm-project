; Make sure drop-able uses triggering UB on poison are not ignored when
; refining flags in use context.
define i32 @no_refine_samesign_extra_droppable_user(i8 %x, i8 %y, i1 %g) {
; CHECK-LABEL: define range(i32 0, 2) i32 @no_refine_samesign_extra_droppable_user(
; CHECK-SAME: i8 [[X:%.*]], i8 [[Y:%.*]], i1 [[G:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[C:%.*]] = icmp slt i8 [[X]], [[Y]]
; CHECK-NEXT:    br i1 [[G]], label %[[THEN:.*]], label %[[ASSUME_BB:.*]]
; CHECK:       [[THEN]]:
; CHECK-NEXT:    [[PX:%.*]] = icmp sgt i8 [[X]], -1
; CHECK-NEXT:    call void @llvm.assume(i1 [[PX]])
; CHECK-NEXT:    [[PY:%.*]] = icmp sgt i8 [[Y]], -1
; CHECK-NEXT:    call void @llvm.assume(i1 [[PY]])
; CHECK-NEXT:    [[R:%.*]] = zext i1 [[C]] to i32
; CHECK-NEXT:    ret i32 [[R]]
; CHECK:       [[ASSUME_BB]]:
; CHECK-NEXT:    call void @llvm.assume(i1 [[C]])
; CHECK-NEXT:    ret i32 0
;
entry:
  %c = icmp slt i8 %x, %y
  br i1 %g, label %then, label %assume_bb

then:
  %px = icmp sgt i8 %x, -1
  call void @llvm.assume(i1 %px)
  %py = icmp sgt i8 %y, -1
  call void @llvm.assume(i1 %py)
  %r = zext i1 %c to i32
  ret i32 %r

assume_bb:
  call void @llvm.assume(i1 %c)
  ret i32 0
}

